# Copie este arquivo para .env.local (desenvolvimento) ou configure as mesmas
# variáveis no provedor de hospedagem antes de gerar o build.
#
# Atenção: toda variável VITE_* é incorporada no JavaScript do navegador. Nunca
# informe aqui segredos de servidor, como service_role do Supabase ou chaves privadas.

# URL pública do backend, incluindo o sufixo /api e sem barra no final.
# Onde obter: URL em que o backend-node-with-AI foi publicado (por exemplo, Cloud
# Run, domínio próprio ou túnel local). Em desenvolvimento local, normalmente é
# http://localhost:<porta>/api.
VITE_API_BASE_URL= 

# URL pública do aplicativo do cliente, sem barra no final. É usada para abrir
# links do cardápio a partir do painel admin.
# Onde obter: domínio configurado para ClienteDeliveryMercado. Em desenvolvimento,
# informe a URL mostrada pelo servidor Vite desse projeto, por exemplo http://localhost:5173.
VITE_CLIENTE_URL=https://cliente.entregaiapp.com.br

# URL do projeto Supabase usada pelo Realtime do salão.
# Onde obter: Supabase Dashboard > projeto correspondente > Connect > Project URL
# (ou Settings > API > Project URL).
VITE_SUPABASE_URL=

# Chave pública anônima/publishable do mesmo projeto Supabase. Não use a chave
# service_role, pois ela concede privilégios administrativos e não pode ir ao navegador.
# Onde obter: Supabase Dashboard > projeto correspondente > Connect, em "Publishable key",
# ou Settings > API > Project API keys, em "anon public".
VITE_SUPABASE_ANON_KEY=

# Configuração do aplicativo Web do Firebase usada para autenticação, analytics e notificações.
# Onde obter cada campo abaixo: Firebase Console > projeto correspondente > ícone de engrenagem
# > Configurações do projeto > Geral > Seus apps > aplicativo Web > Configuração do SDK.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Chave pública VAPID do Firebase Cloud Messaging para notificações web.
# Onde obter: Firebase Console > projeto correspondente > ícone de engrenagem >
# Configurações do projeto > Cloud Messaging > Certificados da Web > Par de chaves.
# Gere um par apenas se ainda não existir um; trocar esta chave invalida inscrições anteriores.
VITE_FIREBASE_VAPID_KEY=
